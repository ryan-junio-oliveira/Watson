# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=120

# Modelo LLM
TEMPERATURE=0.1
MAX_TOKENS=2048

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
INDEX_BATCH_SIZE=100

# Database (MySQL)
DB_CONNECTION_STRING=mysql+pymysql://root:senha@localhost:3306/dokviewermanager
DB_TABLES=["licenses","clients","installations","license_renewal_history"]

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ai_agent.log
